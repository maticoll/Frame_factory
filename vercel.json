{
  "name": "framefactory-pvc",
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "rewrites": [
    { "source": "/producto/:slug", "destination": "/producto/:slug/index.html" },
    { "source": "/producto/:slug/", "destination": "/producto/:slug/index.html" },
    { "source": "/categoria-producto/:slug", "destination": "/categoria-producto/:slug/index.html" },
    { "source": "/categoria-producto/:slug/", "destination": "/categoria-producto/:slug/index.html" }
  ],
  "headers": [
    {
      "source": "/pdf/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "inline"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
